generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpendCategory {
  CLOUD
  SAAS
  AI
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum RenewalStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  RISK
}

enum RecommendationType {
  UNUSED_LICENSE
  RENEWAL_RISK
  HIGH_AI_COST
  CLOUD_IDLE
  BENCHMARK_DEVIATION
}

enum RecommendationStatus {
  OPEN
  ACCEPTED
  DISMISSED
  IMPLEMENTED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  BLOCKED
  DONE
}

enum NegotiationStatus {
  OPEN
  PREPARING
  IN_NEGOTIATION
  WON
  LOST
}

enum ImportStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  createdAt     DateTime @default(now())
  users         User[]
  roles         Role[]
  vendors       Vendor[]
  contracts     Contract[]
  renewals      Renewal[]
  recommendations Recommendation[]
  benchmarkRecords BenchmarkRecord[]
  tcoScenarios  TCOScenario[]
  workflows     Workflow[]
  auditLogs     AuditLog[]
  importJobs    ImportJob[]
}

model User {
  id         String   @id @default(cuid())
  tenantId   String
  email      String
  name       String
  passwordHash String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  roleAssignments UserRole[]

  @@unique([tenantId, email])
}

model Role {
  id       String @id @default(cuid())
  tenantId String
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, name])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Vendor {
  id       String @id @default(cuid())
  tenantId String
  name     String
  category SpendCategory
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  products Product[]
  contracts Contract[]
}

model Product {
  id       String @id @default(cuid())
  tenantId String
  vendorId String
  name     String
  sku      String?
  vendor   Vendor @relation(fields: [vendorId], references: [id])
  plans    Plan[]

  @@unique([tenantId, vendorId, name])
}

model Plan {
  id        String @id @default(cuid())
  tenantId  String
  productId String
  name      String
  unitPrice Decimal @db.Decimal(12,2)
  product   Product @relation(fields: [productId], references: [id])
}

model Contract {
  id           String @id @default(cuid())
  tenantId     String
  vendorId     String
  productId    String?
  status       ContractStatus
  startDate    DateTime
  endDate      DateTime
  annualAmount Decimal @db.Decimal(14,2)
  tenant       Tenant @relation(fields: [tenantId], references: [id])
  vendor       Vendor @relation(fields: [vendorId], references: [id])
  renewals     Renewal[]
}

model Renewal {
  id         String @id @default(cuid())
  tenantId   String
  contractId String
  dueDate    DateTime
  status     RenewalStatus
  ownerId    String?
  contract   Contract @relation(fields: [contractId], references: [id])
  tenant     Tenant @relation(fields: [tenantId], references: [id])
}

model InvoiceLine {
  id          String @id @default(cuid())
  tenantId    String
  vendorId    String
  amount      Decimal @db.Decimal(14,2)
  spendCategory SpendCategory
  serviceDate DateTime
}

model UsageRecord {
  id        String @id @default(cuid())
  tenantId  String
  source    String
  metric    String
  value     Float
  occurredAt DateTime
}

model CostRecord {
  id          String @id @default(cuid())
  tenantId    String
  spendCategory SpendCategory
  serviceName String
  amount      Decimal @db.Decimal(14,2)
  metadata    Json?
  occurredAt  DateTime
}

model Owner {
  id       String @id @default(cuid())
  tenantId String
  name     String
  email    String
}

model Team {
  id            String @id @default(cuid())
  tenantId      String
  name          String
  businessUnitId String?
}

model BusinessUnit {
  id       String @id @default(cuid())
  tenantId String
  name     String
}

model CostCenter {
  id       String @id @default(cuid())
  tenantId String
  code     String
  name     String
}

model BenchmarkRecord {
  id         String @id @default(cuid())
  tenantId   String
  vendorName String
  productName String
  cohort     String
  priceLow   Decimal @db.Decimal(12,2)
  priceMid   Decimal @db.Decimal(12,2)
  priceHigh  Decimal @db.Decimal(12,2)
  confidence Float
  tenant     Tenant @relation(fields: [tenantId], references: [id])
}

model Recommendation {
  id             String @id @default(cuid())
  tenantId       String
  type           RecommendationType
  status         RecommendationStatus @default(OPEN)
  title          String
  explanation    String
  evidence       Json
  estimatedSavings Decimal @db.Decimal(14,2)
  createdAt      DateTime @default(now())
  tenant         Tenant @relation(fields: [tenantId], references: [id])
  actions        RecommendationAction[]
}

model RecommendationAction {
  id               String @id @default(cuid())
  tenantId         String
  recommendationId String
  action           String
  status           String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id])
}

model NegotiationCase {
  id            String @id @default(cuid())
  tenantId      String
  vendorId      String
  status        NegotiationStatus
  targetPrice   Decimal? @db.Decimal(12,2)
  anchorPrice   Decimal? @db.Decimal(12,2)
  walkAwayPrice Decimal? @db.Decimal(12,2)
  notes         NegotiationNote[]
}

model NegotiationNote {
  id         String @id @default(cuid())
  caseId     String
  authorId   String
  note       String
  createdAt  DateTime @default(now())
  case       NegotiationCase @relation(fields: [caseId], references: [id])
}

model TCOScenario {
  id          String @id @default(cuid())
  tenantId    String
  name        String
  assumptions Json
  oneYear     Decimal @db.Decimal(14,2)
  threeYear   Decimal @db.Decimal(14,2)
  fiveYear    Decimal @db.Decimal(14,2)
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  components  TCOComponent[]
}

model TCOComponent {
  id          String @id @default(cuid())
  scenarioId  String
  name        String
  category    String
  yearlyCost  Decimal @db.Decimal(14,2)
  scenario    TCOScenario @relation(fields: [scenarioId], references: [id])
}

model Workflow {
  id         String @id @default(cuid())
  tenantId   String
  name       String
  status     WorkflowStatus
  createdAt  DateTime @default(now())
  tenant     Tenant @relation(fields: [tenantId], references: [id])
  tasks      WorkflowTask[]
}

model WorkflowTask {
  id          String @id @default(cuid())
  workflowId  String
  title       String
  assigneeId  String?
  dueDate     DateTime?
  status      String
  workflow    Workflow @relation(fields: [workflowId], references: [id])
}

model SavingsRealization {
  id               String @id @default(cuid())
  tenantId         String
  recommendationId String?
  amount           Decimal @db.Decimal(14,2)
  realizedAt       DateTime
}

model Policy {
  id          String @id @default(cuid())
  tenantId    String
  key         String
  config      Json

  @@unique([tenantId, key])
}

model AuditLog {
  id          String @id @default(cuid())
  tenantId    String
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  createdAt   DateTime @default(now())
  tenant      Tenant @relation(fields: [tenantId], references: [id])
}

model Connector {
  id          String @id @default(cuid())
  tenantId    String
  type        String
  name        String
  config      Json
  isActive    Boolean @default(true)
}

model ImportJob {
  id           String @id @default(cuid())
  tenantId     String
  connectorId  String?
  sourceType   String
  filename     String
  fileHash     String
  status       ImportStatus @default(RECEIVED)
  idempotencyKey String @unique
  errorMessage String?
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  tenant       Tenant @relation(fields: [tenantId], references: [id])
}
